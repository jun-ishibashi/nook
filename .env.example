# Database (PostgreSQL - Neon)
# https://neon.tech/
DATABASE_URL="postgresql://user:password@ep-host-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="please-generate-a-long-random-string-for-production"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# 検索エンジンに載せない（本番の初期リリースなど）。公開するときは未設定か 0 にして再デプロイ
# NO_INDEX_SITE=1

# 任意: 運営者連絡先（利用規約・プライバシーに表示）
# リンクになるのは次のみ: http(s) URL、/ で始まる同一サイト内パス、mailto:...、単体のメールアドレス
# それ以外はプレーンテキストとして表示されます
# NEXT_PUBLIC_OPERATOR_CONTACT=you@example.com
# NEXT_PUBLIC_OPERATOR_CONTACT=https://example.com/contact
